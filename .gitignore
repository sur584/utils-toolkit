# Dependencies
node_modules/

# Python
__pycache__/
*.pyc
*.pyo

# Downloads
backend/downloads/

# Transcript cache: ignore generated DB, keep source code (store.py, __init__.py)
backend/transcript/cache/*.db
*.mp4
*.part

# Portable Python (auto-downloaded by app.bat)
python/

# AI models (auto-downloaded, ~100MB+)
models/
models/hub/                   # HuggingFace / Whisper 模型缓存

# Cache directory (auto-generated, root only)
/cache/

# History data (personal video history, do not commit)
backend/history_data/

# Backend logs
backend/app.log

# Test files
backend/test_*.py
test_result.txt

# API response dumps (temporary debug artifacts)
/p1.json
/p2.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Output directory (generated by bg-remover)
tools/bg-remover/output/

# Build artifacts
dist/
assets/

# Environment files
.env
*.env
.env.local
